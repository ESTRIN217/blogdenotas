<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="300dp"
    android:layout_height="400dp"
    android:background="@drawable/bg_floating_window"
    android:elevation="8dp">

    <!-- Barra de Título y Controles -->
    <LinearLayout
        android:id="@+id/floating_header"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="?attr/colorPrimary"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/floating_title_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Nota Rápida"
            android:textColor="?attr/colorOnPrimary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"/>

        <ImageButton
            android:id="@+id/btn_guardar_flotante"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/save_24px"
            app:tint="?attr/colorOnPrimary"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Guardar nota flotante"/>

        <ImageButton
            android:id="@+id/btn_cerrar_flotante"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/close_24px"
            app:tint="?attr/colorOnPrimary"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Cerrar nota flotante"/>
    </LinearLayout>

    <!-- Editor de Texto -->
    <EditText
        android:id="@+id/floating_txt_nota"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@android:color/transparent"
        android:gravity="top|start"
        android:hint="Editando nota..."
        android:inputType="textMultiLine|textCapSentences"
        android:padding="16dp"
        android:textColor="?attr/colorOnSurface"
        android:textColorHint="?attr/colorOnSurfaceVariant"
        android:textSize="16sp" />

</LinearLayout>
